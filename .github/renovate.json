{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate rules for cb-events dependency updates.",
  "extends": ["config:best-practices"],
  "automergeType": "branch",
  "branchNameStrict": true,
  "commitMessageLowerCase": "auto",
  "dependencyDashboard": true,
  "dependencyDashboardApproval": false,
  "dependencyDashboardAutoclose": true,
  "enabledManagers": [
    "dockerfile",
    "github-actions",
    "pep621",
    "pep723",
    "pre-commit"
  ],
  "ignorePaths": [
    "**/.pytest_cache/**",
    "**/__pycache__/**",
    "docs/_build/**",
    "htmlcov/**",
    "coverage.xml",
    "junit.xml"
  ],
  "internalChecksAsSuccess": false,
  "internalChecksFilter": "strict",
  "labels": ["dependencies"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"],
    "labels": ["dependencies", "lockfile"],
    "automerge": true,
    "semanticCommitScope": "lock-file",
    "minimumReleaseAge": "0 days"
  },
  "minimumReleaseAge": "8 days",
  "prCreation": "not-pending",
  "platformAutomerge": false,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rangeStrategy": "bump",
  "rebaseWhen": "auto",
  "schedule": ["at any time"],
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "timezone": "America/Edmonton",
  "packageRules": [
    {
      "description": "Major updates require manual review",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "breaking"],
      "automerge": false,
      "assignees": ["MountainGod2"]
    },
    {
      "description": "Runtime dependencies (async HTTP and validation)",
      "matchPackageNames": [
        "aiohttp",
        "aiolimiter",
        "pydantic",
        "stamina",
        "typing-extensions",
        "/^pydantic-.*$/"
      ],
      "groupName": "runtime",
      "labels": ["dependencies", "core"],
      "semanticCommitScope": "runtime"
    },
    {
      "description": "Development tools (testing, linting, and type checking)",
      "matchPackageNames": [
        "pytest",
        "pytest-asyncio",
        "pytest-aiohttp",
        "pytest-cov",
        "pytest-mock",
        "aioresponses",
        "pre-commit",
        "pyrefly",
        "pyright",
        "pylint",
        "ruff",
        "/^pytest-.*$/",
        "/^pylint-.*$/",
        "ty"
      ],
      "groupName": "dev-tools",
      "labels": ["dependencies", "dev"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "autoApprove": true,
      "semanticCommitScope": "dev-tools"
    },
    {
      "description": "Security scanning tools (SAST and dependency audit)",
      "matchPackageNames": ["bandit", "pip-audit", "zizmor"],
      "groupName": "security",
      "labels": ["dependencies", "security"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "autoApprove": true,
      "semanticCommitScope": "security"
    },
    {
      "description": "Documentation tools (Sphinx and extensions)",
      "matchPackageNames": ["sphinx", "furo", "myst-parser", "/^sphinx-.*$/"],
      "groupName": "docs",
      "labels": ["dependencies", "docs"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "autoApprove": true,
      "semanticCommitScope": "docs"
    },
    {
      "description": "Build and release tools",
      "matchPackageNames": [
        "hatchling",
        "hatch-fancy-pypi-readme",
        "python-semantic-release",
        "/^hatch-.*$/"
      ],
      "groupName": "build",
      "labels": ["dependencies", "build"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "autoApprove": true,
      "semanticCommitScope": "build"
    },
    {
      "description": "Pre-commit hooks",
      "matchManagers": ["pre-commit"],
      "groupName": "pre-commit",
      "labels": ["dependencies", "pre-commit"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "autoApprove": true,
      "semanticCommitScope": "pre-commit"
    },
    {
      "description": "GitHub Actions workflows",
      "matchManagers": ["github-actions"],
      "groupName": "ci",
      "labels": ["dependencies", "ci"],
      "automerge": true,
      "autoApprove": true,
      "semanticCommitScope": "ci"
    },
    {
      "description": "Dockerfile updates",
      "matchManagers": ["dockerfile"],
      "groupName": "docker",
      "labels": ["dependencies", "docker"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "autoApprove": true,
      "semanticCommitScope": "docker"
    },
    {
      "description": "Example scripts managed via PEP 723",
      "matchManagers": ["pep723"],
      "groupName": "examples",
      "labels": ["dependencies", "examples"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "autoApprove": true,
      "semanticCommitScope": "examples"
    },
    {
      "description": "Examples dependency group (pyproject.toml)",
      "matchManagers": ["pep621"],
      "matchPackageNames": ["python-dotenv", "rich"],
      "groupName": "examples-deps",
      "labels": ["dependencies", "examples"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "autoApprove": true,
      "semanticCommitScope": "examples-deps"
    },
    {
      "description": "cb-events package in examples scripts",
      "matchManagers": ["pep723"],
      "matchPackageNames": ["cb-events"],
      "labels": ["dependencies", "examples"],
      "minimumReleaseAge": "0 days",
      "semanticCommitScope": "examples-deps"
    },
    {
      "description": "Keep Python version pinned",
      "matchManagers": ["pep621"],
      "ignoreDeps": ["python"]
    },
    {
      "description": "Treat 0.x minor updates as potentially breaking",
      "matchManagers": ["pep621"],
      "matchCurrentVersion": "/^0\\./",
      "matchUpdateTypes": ["minor"],
      "labels": ["dependencies", "breaking"],
      "automerge": false
    }
  ],
  "pep723": {
    "enabled": true,
    "managerFilePatterns": ["/^examples/.*\\.py$/"]
  },
  "pre-commit": {
    "enabled": true
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "automerge": true,
    "labels": ["dependencies", "security"],
    "assignees": ["MountainGod2"],
    "semanticCommitType": "fix",
    "semanticCommitScope": "security"
  },
  "registryAliases": {
    "dhi.io": "dhi.io"
  },
  "hostRules": [
    {
      "matchHost": "dhi.io",
      "hostType": "docker",
      "username": "{{ secrets.MEND_DHI_USERNAME }}",
      "password": "{{ secrets.MEND_DHI_PASSWORD }}"
    }
  ]
}
